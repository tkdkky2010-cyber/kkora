{
  "rules": {
    "heartbeats": {
      "$challengeId": {
        ".read": "auth != null && data.child('userId').val() === auth.uid",
        ".write": "auth != null && (newData.child('userId').val() === auth.uid || data.child('userId').val() === auth.uid)",
        ".validate": "newData.hasChildren(['userId', 'lastPingAt'])",
        "userId": { ".validate": "newData.isString()" },
        "lastPingAt": { ".validate": "newData.isNumber()" },
        "appState": { ".validate": "newData.isString() && (newData.val() === 'active' || newData.val() === 'background')" },
        "batteryLevel": { ".validate": "newData.isNumber() || newData.val() === null" },
        "pingCount": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    }
  }
}
