rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 유저 데이터: 본인만 읽기 가능, balance는 Functions만 수정
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                      .hasAny(['balance', 'totalEarnings', 'freeTrialDaysLeft']);
      // balance, totalEarnings, freeTrialDaysLeft는 Cloud Functions만 수정 가능
    }

    // 챌린지: 본인 것만 읽기, 생성은 가능하나 수정은 Functions만
    match /challenges/{challengeId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      // status, earnings, settledAt 등은 Cloud Functions만 수정
      allow update: if false;
    }

    // 일일 풀: 모든 인증 유저 읽기 가능, 수정은 Functions만
    match /dailyPool/{date} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 유예 로그: 본인 것만 읽기, 수정은 Functions만
    match /graceLogs/{logId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
  }
}
